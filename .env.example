QDRANT_URL=https://xxxxx.us-west-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=op_chunks
NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=xxxxx
GROQ_API_KEY=gsk_xxxxx
OLLAMA_BASE_URL=http://localhost:11434
GROQ_MODEL=llama-3.1-70b-versatile
OLLAMA_MODEL=llama3.1:8b
LOG_LEVEL=INFO
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
# Compatibilite legacy: si OLLAMA_MODEL est absent, LLM_MODEL est utilise pour Ollama.
LLM_MODEL=
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=5
# Poids du reranker (doivent sommer a 1.0)
RERANK_VECTOR_WEIGHT=0.4
RERANK_GRAPH_WEIGHT=0.4
RERANK_KEYWORD_WEIGHT=0.2
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
