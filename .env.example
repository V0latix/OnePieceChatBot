QDRANT_URL=https://xxxxx.us-west-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=op_chunks
NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=xxxxx
GROQ_API_KEY=gsk_xxxxx
OLLAMA_BASE_URL=http://localhost:11434
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_MODEL=llama3.1:8b
LOG_LEVEL=INFO
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
# Compatibilite legacy: si OLLAMA_MODEL est absent, LLM_MODEL est utilise pour Ollama.
LLM_MODEL=
CHUNK_SIZE=500
CHUNK_OVERLAP=50
# Contextual retrieval v1 (prefixe par chunk). Mesure = regression (Hit@5 68->52%),
# laisse OFF. Necessiterait de re-chunker/re-embed le corpus pour prendre effet.
CHUNK_CONTEXTUAL=0
RETRIEVAL_TOP_K=5
# Fusion RRF : k du 1/(k+rang) et poids du biais graphe
RERANK_RRF_K=60
RERANK_GRAPH_BOOST=1.0
# Cross-encoder 2e etage (bge-reranker-v2-m3). 1 pour activer (telecharge ~2.3GB au 1er appel).
# Reordonne les RERANK_CANDIDATES meilleurs candidats RRF via (query, chunk).
RERANK_CROSS_ENCODER=0
CROSS_ENCODER_MODEL=BAAI/bge-reranker-v2-m3
RERANK_CANDIDATES=30
# Personalized PageRank : graph_score continu (proximite graphe) seede sur les entites
# de la question. 1 pour activer (NetworkX sur data/graph/triplets.jsonl, Neo4j non requis).
GRAPH_PPR=0
# HyDE : passage hypothetique EN pour la recherche dense (comble l'ecart FR->EN).
# 1 pour activer (ajoute 1 appel Groq par requete).
HYDE=0
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
